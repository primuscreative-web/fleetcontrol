{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run db:generate && npm run build --workspace @fleetcontrol/api",
  "functions": {
    "api/index.ts": {
      "includeFiles": ["apps/api/dist/**", "packages/**"]
    }
  },
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api" }]
}
