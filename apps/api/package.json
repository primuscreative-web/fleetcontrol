{
  "name": "@fleetcontrol/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "prisma generate --schema ../../packages/database/prisma/schema.prisma && nest build && node -e \"const fs=require('fs');fs.mkdirSync('dist',{recursive:true});fs.copyFileSync('dist/apps/api/src/main.js','dist/main.js')\"",
    "start": "node dist/apps/api/src/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint src",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "jest --config jest.config.cjs --passWithNoTests",
    "test:unit": "jest --config jest.config.cjs --testPathPattern='\\.spec\\.ts$' --passWithNoTests",
    "test:integration": "jest --config jest.config.cjs --testPathPattern='\\.integration-spec\\.ts$' --passWithNoTests",
    "test:e2e": "jest --config jest-e2e.config.cjs --passWithNoTests",
    "test:coverage": "jest --config jest.config.cjs --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.850.0",
    "@fleetcontrol/authz": "file:../../packages/authz",
    "@fleetcontrol/config": "file:../../packages/config",
    "@fleetcontrol/database": "file:../../packages/database",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@supabase/supabase-js": "^2.52.0",
    "argon2": "^0.43.0",
    "cache-manager": "^6.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ua-parser-js": "^2.0.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "prisma": "^6.19.3",
    "@nestjs/cli": "^11.0.7",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.16.5",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@types/ua-parser-js": "^0.7.39",
    "jest": "^29.7.0",
    "supertest": "^7.1.3",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.3"
  }
}
