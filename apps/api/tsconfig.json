{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "noEmit": false,
    "outDir": "dist",
    "paths": {
      "@fleetcontrol/authz": ["../../packages/authz/src"],
      "@fleetcontrol/config": ["../../packages/config/src"],
      "@fleetcontrol/database": ["../../packages/database/src"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.integration-spec.ts"]
}
