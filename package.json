{
  "name": "fleetcontrol",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise SaaS platform for fleet management.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @fleetcontrol/web",
    "dev:web": "npm run dev --workspace @fleetcontrol/web",
    "dev:api": "npm run start:dev --workspace @fleetcontrol/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "npm run prisma:generate --workspace @fleetcontrol/database",
    "db:migrate": "npm run prisma:migrate --workspace @fleetcontrol/database",
    "db:deploy": "npm run prisma:deploy --workspace @fleetcontrol/database",
    "db:seed": "npm run prisma:seed --workspace @fleetcontrol/database",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.31.0",
    "@next/eslint-plugin-next": "^15.5.20",
    "@types/node": "^22.16.5",
    "eslint": "^9.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "next": "^15.5.20",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "lint-staged": {
    "apps/*/src/**/*.{ts,tsx,js,jsx}": "eslint --fix",
    "packages/*/src/**/*.{ts,tsx,js,jsx}": "eslint --fix",
    "*.{json,md,css,scss,yml,yaml}": "prettier --write"
  }
}
