generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum MembershipStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_CHANGED
  ACCESS_DENIED
  SESSION_REVOKED
}

enum NotificationChannel {
  INTERNAL
  EMAIL
  PUSH
  WHATSAPP
  SMS
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationStatus {
  SCHEDULED
  SENT
  READ
  ARCHIVED
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

enum FeatureFlagStatus {
  ENABLED
  DISABLED
}

enum VehicleStatus {
  AVAILABLE
  OPERATING
  ON_TRIP
  IN_MAINTENANCE
  STOPPED
  BLOCKED
  RESERVED
  INACTIVE
  WRITTEN_OFF
}

enum VehicleFuelType {
  GASOLINE
  ETHANOL
  FLEX
  DIESEL
  BIODIESEL
  ELECTRIC
  HYBRID
  CNG
  OTHER
}

enum VehicleDocumentType {
  CRLV
  IPVA
  INSURANCE
  LICENSING
  ANTT
  TACHOGRAPH
  CHRONOTACHOGRAPH
  OTHER
}

enum VehicleTimelineType {
  CREATED
  UPDATED
  TRANSFERRED
  STATUS_CHANGED
  DOCUMENT_UPLOADED
  PHOTO_ADDED
  CHECKLIST
  DRIVER
  FUELING
  FINE
  TIRE
  MAINTENANCE
  CONTRACT
  ARCHIVED
}

enum VehicleCostType {
  FUEL
  TIRES
  WORKSHOP
  PARTS
  INSURANCE
  IPVA
  LICENSING
  TOLLS
  FINES
  OTHER
}

enum DriverStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  INACTIVE
  TERMINATED
}

enum DriverDocumentType {
  CNH
  MEDICAL_CERTIFICATE
  TOXICOLOGY_EXAM
  TRAINING_CERTIFICATE
  IDENTITY
  ADDRESS_PROOF
  OTHER
}

enum DriverTimelineType {
  CREATED
  UPDATED
  STATUS_CHANGED
  VEHICLE_ASSIGNED
  VEHICLE_UNASSIGNED
  DOCUMENT_UPLOADED
  ALERT_CREATED
  ARCHIVED
}

enum ContractStatus {
  DRAFT
  BIDDING
  ACTIVE
  SUSPENDED
  EXPIRED
  TERMINATED
  CANCELLED
}

enum ContractType {
  PUBLIC_BID
  DIRECT_AWARD
  FRAMEWORK
  PRIVATE
}

enum ContractDocumentType {
  NOTICE
  PROPOSAL
  CONTRACT
  AMENDMENT
  GUARANTEE
  CERTIFICATE
  INVOICE
  OTHER
}

enum ContractTimelineType {
  CREATED
  UPDATED
  STATUS_CHANGED
  AMENDMENT_ADDED
  DOCUMENT_UPLOADED
  VEHICLE_ALLOCATED
  VEHICLE_RELEASED
  ALERT_CREATED
  ARCHIVED
}

enum FuelingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum FuelingSource {
  MANUAL
  IMPORT
  FUEL_CARD
  INTEGRATION
}

model Company {
  id                   String                      @id @default(cuid())
  name                 String
  legalName            String?
  document             String?                     @unique
  status               CompanyStatus               @default(ACTIVE)
  logoUrl              String?
  defaultLanguage      String                      @default("pt-BR")
  defaultTimezone      String                      @default("America/Sao_Paulo")
  defaultCurrency      String                      @default("BRL")
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  branches             Branch[]
  departments          Department[]
  teams                Team[]
  positions            Position[]
  memberships          Membership[]
  roles                Role[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  settings             Setting[]
  featureFlags         FeatureFlag[]
  outboxEvents         OutboxEvent[]
  passwordResetTokens  PasswordResetToken[]
  costCenters          CostCenter[]
  vehicleCategories    VehicleCategory[]
  vehicleSubcategories VehicleSubcategory[]
  vehicleMakes         VehicleMake[]
  vehicleModels        VehicleModel[]
  vehicleVersions      VehicleVersion[]
  vehicles             Vehicle[]
  vehiclePhotos        VehiclePhoto[]
  vehicleDocuments     VehicleDocument[]
  vehicleTimeline      VehicleTimelineEvent[]
  vehicleCosts         VehicleCostAggregate[]
  vehicleSavedFilters  VehicleSavedFilter[]
  drivers              Driver[]
  driverDocuments      DriverDocument[]
  driverAssignments    DriverVehicleAssignment[]
  driverTimeline       DriverTimelineEvent[]
  contracts            Contract[]
  contractAmendments   ContractAmendment[]
  contractDocuments    ContractDocument[]
  contractAllocations  ContractVehicleAllocation[]
  contractTimeline     ContractTimelineEvent[]
  fuelStations         FuelStation[]
  fuelPrices           FuelPrice[]
  fuelings             Fueling[]

  @@index([status])
}

model Branch {
  id           String        @id @default(cuid())
  name         String
  code         String?
  companyId    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departments  Department[]
  memberships  Membership[]
  costCenters  CostCenter[]
  vehicles     Vehicle[]
  drivers      Driver[]
  contracts    Contract[]
  fuelStations FuelStation[]
  fuelings     Fueling[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Department {
  id          String       @id @default(cuid())
  name        String
  code        String?
  companyId   String
  branchId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  teams       Team[]
  memberships Membership[]
  vehicles    Vehicle[]
  drivers     Driver[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([branchId])
}

model Team {
  id           String       @id @default(cuid())
  name         String
  companyId    String
  departmentId String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  memberships  Membership[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([departmentId])
}

model Position {
  id          String       @id @default(cuid())
  name        String
  companyId   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberships Membership[]

  @@unique([companyId, name])
  @@index([companyId])
}

model User {
  id                  String                      @id @default(cuid())
  name                String
  email               String                      @unique
  passwordHash        String
  emailVerifiedAt     DateTime?
  passwordChangedAt   DateTime?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  memberships         Membership[]
  sessions            Session[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  vehiclePhotos       VehiclePhoto[]
  vehicleDocuments    VehicleDocument[]
  vehicleTimeline     VehicleTimelineEvent[]
  vehicleSavedFilters VehicleSavedFilter[]
  driverProfiles      Driver[]
  driverDocuments     DriverDocument[]
  driverAssignments   DriverVehicleAssignment[]
  driverTimeline      DriverTimelineEvent[]
  managedContracts    Contract[]
  contractAmendments  ContractAmendment[]
  contractDocuments   ContractDocument[]
  contractAllocations ContractVehicleAllocation[]
  contractTimeline    ContractTimelineEvent[]
  fuelPricesCreated   FuelPrice[]
  fuelingsCreated     Fueling[]                   @relation("FuelingCreatedBy")
  fuelingsApproved    Fueling[]                   @relation("FuelingApprovedBy")
}

model Membership {
  id           String           @id @default(cuid())
  status       MembershipStatus @default(ACTIVE)
  companyId    String
  userId       String
  roleId       String
  branchId     String?
  departmentId String?
  teamId       String?
  positionId   String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role             @relation(fields: [roleId], references: [id], onDelete: Restrict)
  branch       Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department   Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  team         Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  position     Position?        @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@unique([companyId, userId])
  @@index([companyId, status])
  @@index([roleId])
  @@index([branchId])
  @@index([departmentId])
}

model Role {
  id          String           @id @default(cuid())
  scopeId     String           @default("system")
  key         String
  name        String
  description String?
  companyId   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  company     Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberships Membership[]
  permissions RolePermission[]

  @@unique([scopeId, key])
  @@index([companyId])
}

model Permission {
  id          String           @id @default(cuid())
  resource    String
  action      String
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]

  @@unique([resource, action])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  conditions   Json?
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Session {
  id               String        @id @default(cuid())
  userId           String
  companyId        String?
  refreshTokenHash String        @unique
  status           SessionStatus @default(ACTIVE)
  rememberMe       Boolean       @default(false)
  ipAddress        String?
  userAgent        String?
  browser          String?
  operatingSystem  String?
  device           String?
  lastSeenAt       DateTime      @default(now())
  revokedAt        DateTime?
  expiresAt        DateTime
  createdAt        DateTime      @default(now())
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([companyId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  companyId String?
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([expiresAt])
}

model AuditLog {
  id              String      @id @default(cuid())
  action          AuditAction
  tableName       String
  recordId        String?
  oldValue        Json?
  newValue        Json?
  metadata        Json?
  ipAddress       String?
  userAgent       String?
  browser         String?
  operatingSystem String?
  device          String?
  companyId       String?
  actorId         String?
  createdAt       DateTime    @default(now())
  company         Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  actor           User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([actorId, createdAt])
  @@index([tableName, recordId])
}

model Notification {
  id          String               @id @default(cuid())
  companyId   String?
  userId      String?
  channel     NotificationChannel  @default(INTERNAL)
  category    String
  title       String
  body        String
  priority    NotificationPriority @default(NORMAL)
  status      NotificationStatus   @default(SENT)
  readAt      DateTime?
  scheduledAt DateTime?
  sentAt      DateTime?
  metadata    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  company     Company?             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([userId, status])
  @@index([scheduledAt])
}

model Setting {
  id        String   @id @default(cuid())
  ownerId   String   @default("system")
  companyId String?
  scope     String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([ownerId, scope, key])
  @@index([companyId])
}

model FeatureFlag {
  id          String            @id @default(cuid())
  ownerId     String            @default("system")
  companyId   String?
  key         String
  description String?
  status      FeatureFlagStatus @default(DISABLED)
  rules       Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  company     Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([ownerId, key])
  @@index([companyId, status])
}

model OutboxEvent {
  id            String            @id @default(cuid())
  companyId     String?
  name          String
  aggregateType String
  aggregateId   String?
  payload       Json
  status        OutboxEventStatus @default(PENDING)
  attempts      Int               @default(0)
  lastError     String?
  publishedAt   DateTime?
  createdAt     DateTime          @default(now())
  company       Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([status, createdAt])
  @@index([name])
}

model CostCenter {
  id        String    @id @default(cuid())
  name      String
  code      String?
  companyId String
  branchId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  vehicles  Vehicle[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([branchId])
}

model VehicleCategory {
  id            String               @id @default(cuid())
  name          String
  code          String?
  companyId     String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subcategories VehicleSubcategory[]
  vehicles      Vehicle[]

  @@unique([companyId, name])
  @@index([companyId])
}

model VehicleSubcategory {
  id         String          @id @default(cuid())
  name       String
  code       String?
  companyId  String
  categoryId String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  company    Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category   VehicleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  vehicles   Vehicle[]

  @@unique([companyId, categoryId, name])
  @@index([companyId])
  @@index([categoryId])
}

model VehicleMake {
  id        String         @id @default(cuid())
  name      String
  companyId String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  models    VehicleModel[]
  vehicles  Vehicle[]

  @@unique([companyId, name])
  @@index([companyId])
}

model VehicleModel {
  id        String           @id @default(cuid())
  name      String
  companyId String
  makeId    String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  make      VehicleMake      @relation(fields: [makeId], references: [id], onDelete: Cascade)
  versions  VehicleVersion[]
  vehicles  Vehicle[]

  @@unique([companyId, makeId, name])
  @@index([companyId])
  @@index([makeId])
}

model VehicleVersion {
  id        String       @id @default(cuid())
  name      String
  companyId String
  modelId   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  model     VehicleModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  vehicles  Vehicle[]

  @@unique([companyId, modelId, name])
  @@index([companyId])
  @@index([modelId])
}

model Vehicle {
  id                  String                      @id @default(cuid())
  companyId           String
  branchId            String?
  departmentId        String?
  costCenterId        String?
  contractId          String?
  categoryId          String?
  subcategoryId       String?
  makeId              String?
  modelId             String?
  versionId           String?
  manufactureYear     Int?
  modelYear           Int?
  color               String?
  plate               String
  renavam             String?
  chassis             String?
  engineNumber        String?
  power               String?
  fuelType            VehicleFuelType?
  capacity            String?
  grossWeight         Decimal?                    @db.Decimal(12, 2)
  netWeight           Decimal?                    @db.Decimal(12, 2)
  axleCount           Int?
  vehicleType         String?
  operationalCategory String?
  status              VehicleStatus               @default(AVAILABLE)
  estimatedValue      Decimal?                    @db.Decimal(14, 2)
  currentOdometer     Decimal?                    @db.Decimal(14, 2)
  observations        String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  archivedAt          DateTime?
  company             Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch              Branch?                     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department          Department?                 @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  costCenter          CostCenter?                 @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  category            VehicleCategory?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory         VehicleSubcategory?         @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  make                VehicleMake?                @relation(fields: [makeId], references: [id], onDelete: SetNull)
  model               VehicleModel?               @relation(fields: [modelId], references: [id], onDelete: SetNull)
  version             VehicleVersion?             @relation(fields: [versionId], references: [id], onDelete: SetNull)
  contract            Contract?                   @relation(fields: [contractId], references: [id], onDelete: SetNull)
  photos              VehiclePhoto[]
  documents           VehicleDocument[]
  timeline            VehicleTimelineEvent[]
  costs               VehicleCostAggregate[]
  driverAssignments   DriverVehicleAssignment[]
  contractAllocations ContractVehicleAllocation[]
  fuelings            Fueling[]

  @@unique([companyId, plate])
  @@unique([companyId, renavam])
  @@unique([companyId, chassis])
  @@index([companyId, status])
  @@index([companyId, branchId])
  @@index([companyId, departmentId])
  @@index([companyId, makeId])
  @@index([companyId, modelId])
  @@index([companyId, categoryId])
  @@index([companyId, archivedAt])
}

model Contract {
  id                String                      @id @default(cuid())
  companyId         String
  branchId          String?
  managerUserId     String?
  number            String
  biddingNumber     String?
  title             String
  object            String
  clientName        String
  clientDocument    String?
  agency            String?
  type              ContractType
  status            ContractStatus              @default(DRAFT)
  startsAt          DateTime
  endsAt            DateTime
  signedAt          DateTime?
  totalValue        Decimal                     @db.Decimal(16, 2)
  consumedValue     Decimal                     @default(0) @db.Decimal(16, 2)
  guaranteeValue    Decimal?                    @db.Decimal(16, 2)
  renewalNoticeDays Int                         @default(60)
  notes             String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  archivedAt        DateTime?
  company           Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch            Branch?                     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  manager           User?                       @relation(fields: [managerUserId], references: [id], onDelete: SetNull)
  vehicles          Vehicle[]
  amendments        ContractAmendment[]
  documents         ContractDocument[]
  allocations       ContractVehicleAllocation[]
  timeline          ContractTimelineEvent[]

  @@unique([companyId, number])
  @@index([companyId, status])
  @@index([companyId, endsAt])
  @@index([companyId, branchId])
  @@index([managerUserId])
  @@index([archivedAt])
}

model ContractAmendment {
  id            String    @id @default(cuid())
  companyId     String
  contractId    String
  number        String
  description   String
  signedAt      DateTime?
  effectiveAt   DateTime
  previousEndAt DateTime?
  newEndAt      DateTime?
  valueChange   Decimal   @default(0) @db.Decimal(16, 2)
  createdById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contract      Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  createdBy     User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([contractId, number])
  @@index([companyId, effectiveAt])
  @@index([createdById])
}

model ContractDocument {
  id              String               @id @default(cuid())
  companyId       String
  contractId      String
  type            ContractDocumentType
  storageKey      String
  url             String
  fileName        String
  mimeType        String
  sizeInBytes     Int?
  issueDate       DateTime?
  expiresAt       DateTime?
  alertDaysBefore Int                  @default(30)
  notes           String?
  uploadedById    String?
  uploadedAt      DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contract        Contract             @relation(fields: [contractId], references: [id], onDelete: Cascade)
  uploadedBy      User?                @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([companyId, expiresAt])
  @@index([contractId, type])
  @@index([uploadedById])
}

model ContractVehicleAllocation {
  id            String    @id @default(cuid())
  companyId     String
  contractId    String
  vehicleId     String
  startsAt      DateTime  @default(now())
  endsAt        DateTime?
  monthlyValue  Decimal?  @db.Decimal(14, 2)
  notes         String?
  allocatedById String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contract      Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  allocatedBy   User?     @relation(fields: [allocatedById], references: [id], onDelete: SetNull)

  @@index([companyId, endsAt])
  @@index([contractId, startsAt])
  @@index([vehicleId, endsAt])
}

model ContractTimelineEvent {
  id          String               @id @default(cuid())
  companyId   String
  contractId  String
  type        ContractTimelineType
  title       String
  description String?
  metadata    Json?
  actorId     String?
  createdAt   DateTime             @default(now())
  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contract    Contract             @relation(fields: [contractId], references: [id], onDelete: Cascade)
  actor       User?                @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([contractId, createdAt])
  @@index([actorId])
}

model Driver {
  id                      String                    @id @default(cuid())
  companyId               String
  branchId                String?
  departmentId            String?
  userId                  String?
  name                    String
  cpf                     String
  cnhNumber               String
  cnhCategory             String
  cnhIssuedAt             DateTime?
  cnhExpiresAt            DateTime
  birthDate               DateTime?
  hireDate                DateTime?
  terminationDate         DateTime?
  phone                   String?
  email                   String?
  status                  DriverStatus              @default(ACTIVE)
  medicalExamExpiresAt    DateTime?
  toxicologyExamExpiresAt DateTime?
  notes                   String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  archivedAt              DateTime?
  company                 Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch                  Branch?                   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department              Department?               @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  user                    User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  documents               DriverDocument[]
  assignments             DriverVehicleAssignment[]
  timeline                DriverTimelineEvent[]
  fuelings                Fueling[]

  @@unique([companyId, cpf])
  @@unique([companyId, cnhNumber])
  @@index([companyId, status])
  @@index([companyId, branchId])
  @@index([companyId, cnhExpiresAt])
  @@index([companyId, medicalExamExpiresAt])
  @@index([userId])
  @@index([archivedAt])
}

model DriverDocument {
  id              String             @id @default(cuid())
  companyId       String
  driverId        String
  type            DriverDocumentType
  storageKey      String
  url             String
  fileName        String
  mimeType        String
  sizeInBytes     Int?
  issueDate       DateTime?
  expiresAt       DateTime?
  alertDaysBefore Int                @default(30)
  notes           String?
  uploadedById    String?
  uploadedAt      DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driver          Driver             @relation(fields: [driverId], references: [id], onDelete: Cascade)
  uploadedBy      User?              @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([companyId, expiresAt])
  @@index([driverId, type])
  @@index([uploadedById])
}

model DriverVehicleAssignment {
  id           String    @id @default(cuid())
  companyId    String
  driverId     String
  vehicleId    String
  startsAt     DateTime  @default(now())
  endsAt       DateTime?
  isPrimary    Boolean   @default(true)
  notes        String?
  assignedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driver       Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  assignedBy   User?     @relation(fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([companyId, endsAt])
  @@index([driverId, startsAt])
  @@index([vehicleId, endsAt])
}

model DriverTimelineEvent {
  id          String             @id @default(cuid())
  companyId   String
  driverId    String
  type        DriverTimelineType
  title       String
  description String?
  metadata    Json?
  actorId     String?
  createdAt   DateTime           @default(now())
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  driver      Driver             @relation(fields: [driverId], references: [id], onDelete: Cascade)
  actor       User?              @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([driverId, createdAt])
  @@index([actorId])
}

model FuelStation {
  id         String      @id @default(cuid())
  companyId  String
  branchId   String?
  name       String
  legalName  String?
  document   String?
  code       String?
  address    String?
  city       String?
  state      String?
  latitude   Decimal?    @db.Decimal(10, 7)
  longitude  Decimal?    @db.Decimal(10, 7)
  active     Boolean     @default(true)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  archivedAt DateTime?
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch     Branch?     @relation(fields: [branchId], references: [id], onDelete: SetNull)
  prices     FuelPrice[]
  fuelings   Fueling[]

  @@unique([companyId, name])
  @@unique([companyId, code])
  @@index([companyId, active])
  @@index([branchId])
}

model FuelPrice {
  id          String          @id @default(cuid())
  companyId   String
  stationId   String
  fuelType    VehicleFuelType
  price       Decimal         @db.Decimal(12, 4)
  effectiveAt DateTime
  expiresAt   DateTime?
  createdById String?
  createdAt   DateTime        @default(now())
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  station     FuelStation     @relation(fields: [stationId], references: [id], onDelete: Cascade)
  createdBy   User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyId, fuelType, effectiveAt])
  @@index([stationId, fuelType, effectiveAt])
  @@index([createdById])
}

model Fueling {
  id                String          @id @default(cuid())
  companyId         String
  branchId          String?
  stationId         String
  vehicleId         String
  driverId          String?
  fuelType          VehicleFuelType
  status            FuelingStatus   @default(PENDING)
  source            FuelingSource   @default(MANUAL)
  fueledAt          DateTime
  odometer          Decimal         @db.Decimal(14, 2)
  liters            Decimal         @db.Decimal(12, 3)
  unitPrice         Decimal         @db.Decimal(12, 4)
  totalAmount       Decimal         @db.Decimal(14, 2)
  previousOdometer  Decimal?        @db.Decimal(14, 2)
  distanceTraveled  Decimal?        @db.Decimal(14, 2)
  consumptionKmPerL Decimal?        @db.Decimal(12, 3)
  fullTank          Boolean         @default(true)
  invoiceNumber     String?
  externalId        String?
  receiptStorageKey String?
  receiptUrl        String?
  anomaly           Boolean         @default(false)
  anomalyReason     String?
  notes             String?
  createdById       String?
  approvedById      String?
  approvedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch            Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  station           FuelStation     @relation(fields: [stationId], references: [id], onDelete: Restrict)
  vehicle           Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver            Driver?         @relation(fields: [driverId], references: [id], onDelete: SetNull)
  createdBy         User?           @relation("FuelingCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy        User?           @relation("FuelingApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@unique([companyId, externalId])
  @@index([companyId, fueledAt])
  @@index([companyId, status])
  @@index([companyId, anomaly])
  @@index([vehicleId, fueledAt])
  @@index([driverId, fueledAt])
  @@index([stationId, fueledAt])
  @@index([branchId])
  @@index([createdById])
  @@index([approvedById])
}

model VehiclePhoto {
