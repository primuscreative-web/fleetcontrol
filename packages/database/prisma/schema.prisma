generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum MembershipStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_CHANGED
  ACCESS_DENIED
  SESSION_REVOKED
}

enum NotificationChannel {
  INTERNAL
  EMAIL
  PUSH
  WHATSAPP
  SMS
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationStatus {
  SCHEDULED
  SENT
  READ
  ARCHIVED
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

enum FeatureFlagStatus {
  ENABLED
  DISABLED
}

enum VehicleStatus {
  AVAILABLE
  OPERATING
  ON_TRIP
  IN_MAINTENANCE
  STOPPED
  BLOCKED
  RESERVED
  INACTIVE
  WRITTEN_OFF
}

enum VehicleFuelType {
  GASOLINE
  ETHANOL
  FLEX
  DIESEL
  BIODIESEL
  ELECTRIC
  HYBRID
  CNG
  OTHER
}

enum VehicleDocumentType {
  CRLV
  IPVA
  INSURANCE
  LICENSING
  ANTT
  TACHOGRAPH
  CHRONOTACHOGRAPH
  OTHER
}

enum VehicleTimelineType {
  CREATED
  UPDATED
  TRANSFERRED
  STATUS_CHANGED
  DOCUMENT_UPLOADED
  PHOTO_ADDED
  CHECKLIST
  DRIVER
  FUELING
  FINE
  TIRE
  MAINTENANCE
  CONTRACT
  ARCHIVED
}

enum VehicleCostType {
  FUEL
  TIRES
  WORKSHOP
  PARTS
  INSURANCE
  IPVA
  LICENSING
  TOLLS
  FINES
  OTHER
}

model Company {
  id                  String               @id @default(cuid())
  name                String
  legalName           String?
  document            String?              @unique
  status              CompanyStatus        @default(ACTIVE)
  logoUrl             String?
  defaultLanguage     String               @default("pt-BR")
  defaultTimezone     String               @default("America/Sao_Paulo")
  defaultCurrency     String               @default("BRL")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  branches            Branch[]
  departments         Department[]
  teams               Team[]
  positions           Position[]
  memberships         Membership[]
  roles               Role[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  settings            Setting[]
  featureFlags        FeatureFlag[]
  outboxEvents        OutboxEvent[]
  passwordResetTokens PasswordResetToken[]
  costCenters         CostCenter[]
  vehicleCategories   VehicleCategory[]
  vehicleSubcategories VehicleSubcategory[]
  vehicleMakes        VehicleMake[]
  vehicleModels       VehicleModel[]
  vehicleVersions     VehicleVersion[]
  vehicles            Vehicle[]
  vehiclePhotos       VehiclePhoto[]
  vehicleDocuments    VehicleDocument[]
  vehicleTimeline     VehicleTimelineEvent[]
  vehicleCosts        VehicleCostAggregate[]
  vehicleSavedFilters VehicleSavedFilter[]

  @@index([status])
}

model Branch {
  id          String       @id @default(cuid())
  name        String
  code        String?
  companyId   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departments Department[]
  memberships Membership[]
  costCenters CostCenter[]
  vehicles    Vehicle[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Department {
  id          String       @id @default(cuid())
  name        String
  code        String?
  companyId   String
  branchId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  teams       Team[]
  memberships Membership[]
  vehicles    Vehicle[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([branchId])
}

model Team {
  id           String       @id @default(cuid())
  name         String
  companyId    String
  departmentId String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  memberships  Membership[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([departmentId])
}

model Position {
  id          String       @id @default(cuid())
  name        String
  companyId   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberships Membership[]

  @@unique([companyId, name])
  @@index([companyId])
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String
  emailVerifiedAt     DateTime?
  passwordChangedAt   DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  memberships         Membership[]
  sessions            Session[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  vehiclePhotos       VehiclePhoto[]
  vehicleDocuments    VehicleDocument[]
  vehicleTimeline     VehicleTimelineEvent[]
  vehicleSavedFilters VehicleSavedFilter[]
}

model Membership {
  id           String           @id @default(cuid())
  status       MembershipStatus @default(ACTIVE)
  companyId    String
  userId       String
  roleId       String
  branchId     String?
  departmentId String?
  teamId       String?
  positionId   String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role             @relation(fields: [roleId], references: [id], onDelete: Restrict)
  branch       Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department   Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  team         Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  position     Position?        @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@unique([companyId, userId])
  @@index([companyId, status])
  @@index([roleId])
  @@index([branchId])
  @@index([departmentId])
}

model Role {
  id          String           @id @default(cuid())
  scopeId     String           @default("system")
  key         String
  name        String
  description String?
  companyId   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  company     Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberships Membership[]
  permissions RolePermission[]

  @@unique([scopeId, key])
  @@index([companyId])
}

model Permission {
  id          String           @id @default(cuid())
  resource    String
  action      String
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]

  @@unique([resource, action])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  conditions   Json?
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Session {
  id               String        @id @default(cuid())
  userId           String
  companyId        String?
  refreshTokenHash String        @unique
  status           SessionStatus @default(ACTIVE)
  rememberMe       Boolean       @default(false)
  ipAddress        String?
  userAgent        String?
  browser          String?
  operatingSystem  String?
  device           String?
  lastSeenAt       DateTime      @default(now())
  revokedAt        DateTime?
  expiresAt        DateTime
  createdAt        DateTime      @default(now())
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([companyId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  companyId String?
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([expiresAt])
}

model AuditLog {
  id              String      @id @default(cuid())
  action          AuditAction
  tableName       String
  recordId        String?
  oldValue        Json?
  newValue        Json?
  metadata        Json?
  ipAddress       String?
  userAgent       String?
  browser         String?
  operatingSystem String?
  device          String?
  companyId       String?
  actorId         String?
  createdAt       DateTime    @default(now())
  company         Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  actor           User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([actorId, createdAt])
  @@index([tableName, recordId])
}

model Notification {
  id          String               @id @default(cuid())
  companyId   String?
  userId      String?
  channel     NotificationChannel  @default(INTERNAL)
  category    String
  title       String
  body        String
  priority    NotificationPriority @default(NORMAL)
  status      NotificationStatus   @default(SENT)
  readAt      DateTime?
  scheduledAt DateTime?
  sentAt      DateTime?
  metadata    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  company     Company?             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User?                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([userId, status])
  @@index([scheduledAt])
}

model Setting {
  id        String   @id @default(cuid())
  ownerId   String   @default("system")
  companyId String?
  scope     String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([ownerId, scope, key])
  @@index([companyId])
}

model FeatureFlag {
  id          String            @id @default(cuid())
  ownerId     String            @default("system")
  companyId   String?
  key         String
  description String?
  status      FeatureFlagStatus @default(DISABLED)
  rules       Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  company     Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([ownerId, key])
  @@index([companyId, status])
}

model OutboxEvent {
  id            String            @id @default(cuid())
  companyId     String?
  name          String
  aggregateType String
  aggregateId   String?
  payload       Json
  status        OutboxEventStatus @default(PENDING)
  attempts      Int               @default(0)
  lastError     String?
  publishedAt   DateTime?
  createdAt     DateTime          @default(now())
  company       Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([status, createdAt])
  @@index([name])
}

model CostCenter {
  id        String    @id @default(cuid())
  name      String
  code      String?
  companyId String
  branchId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  vehicles  Vehicle[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([branchId])
}

model VehicleCategory {
  id            String               @id @default(cuid())
  name          String
  code          String?
  companyId     String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  company       Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subcategories VehicleSubcategory[]
  vehicles      Vehicle[]

  @@unique([companyId, name])
  @@index([companyId])
}

model VehicleSubcategory {
  id         String          @id @default(cuid())
  name       String
  code       String?
  companyId  String
  categoryId String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  company    Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category   VehicleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  vehicles   Vehicle[]

  @@unique([companyId, categoryId, name])
  @@index([companyId])
  @@index([categoryId])
}

model VehicleMake {
  id        String         @id @default(cuid())
  name      String
  companyId String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  models    VehicleModel[]
  vehicles  Vehicle[]

  @@unique([companyId, name])
  @@index([companyId])
}

model VehicleModel {
  id        String           @id @default(cuid())
  name      String
  companyId String
  makeId    String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  make      VehicleMake      @relation(fields: [makeId], references: [id], onDelete: Cascade)
  versions  VehicleVersion[]
  vehicles  Vehicle[]

  @@unique([companyId, makeId, name])
  @@index([companyId])
  @@index([makeId])
}

model VehicleVersion {
  id        String       @id @default(cuid())
  name      String
  companyId String
  modelId   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  model     VehicleModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  vehicles  Vehicle[]

  @@unique([companyId, modelId, name])
  @@index([companyId])
  @@index([modelId])
}

model Vehicle {
  id                  String                 @id @default(cuid())
  companyId           String
  branchId            String?
  departmentId        String?
  costCenterId        String?
  contractId          String?
  categoryId          String?
  subcategoryId       String?
  makeId              String?
  modelId             String?
  versionId           String?
  manufactureYear     Int?
  modelYear           Int?
  color               String?
  plate               String
  renavam             String?
  chassis             String?
  engineNumber        String?
  power               String?
  fuelType            VehicleFuelType?
  capacity            String?
  grossWeight         Decimal?               @db.Decimal(12, 2)
  netWeight           Decimal?               @db.Decimal(12, 2)
  axleCount           Int?
  vehicleType         String?
  operationalCategory String?
  status              VehicleStatus          @default(AVAILABLE)
  estimatedValue      Decimal?               @db.Decimal(14, 2)
  currentOdometer     Decimal?               @db.Decimal(14, 2)
  observations        String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  archivedAt          DateTime?
  company             Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch              Branch?                @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department          Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  costCenter          CostCenter?            @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  category            VehicleCategory?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory         VehicleSubcategory?    @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  make                VehicleMake?           @relation(fields: [makeId], references: [id], onDelete: SetNull)
  model               VehicleModel?          @relation(fields: [modelId], references: [id], onDelete: SetNull)
  version             VehicleVersion?        @relation(fields: [versionId], references: [id], onDelete: SetNull)
  photos              VehiclePhoto[]
  documents           VehicleDocument[]
  timeline            VehicleTimelineEvent[]
  costs               VehicleCostAggregate[]

  @@unique([companyId, plate])
  @@unique([companyId, renavam])
  @@unique([companyId, chassis])
  @@index([companyId, status])
  @@index([companyId, branchId])
  @@index([companyId, departmentId])
  @@index([companyId, makeId])
  @@index([companyId, modelId])
  @@index([companyId, categoryId])
  @@index([companyId, archivedAt])
}

model VehiclePhoto {
  id           String   @id @default(cuid())
  vehicleId    String
  companyId    String
  storageKey   String
  url          String
  fileName     String
  mimeType     String
  sizeInBytes  Int?
  isPrimary    Boolean  @default(false)
  metadata     Json?
  uploadedById String?
  uploadedAt   DateTime @default(now())
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([vehicleId, uploadedAt])
  @@index([companyId])
  @@index([uploadedById])
}

model VehicleDocument {
  id                String              @id @default(cuid())
  vehicleId         String
  companyId         String
  type              VehicleDocumentType
  storageKey        String
  url               String
  fileName          String
  mimeType          String
  sizeInBytes       Int?
  issueDate         DateTime?
  expiresAt         DateTime?
  responsibleUserId String?
  responsibleName   String?
  notes             String?
  alertDaysBefore   Int                 @default(30)
  uploadedAt        DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  vehicle           Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  responsibleUser   User?               @relation(fields: [responsibleUserId], references: [id], onDelete: SetNull)

  @@index([vehicleId, type])
  @@index([companyId, expiresAt])
  @@index([responsibleUserId])
}

model VehicleTimelineEvent {
  id          String              @id @default(cuid())
  vehicleId   String
  companyId   String
  type        VehicleTimelineType
  title       String
  description String?
  metadata    Json?
  actorId     String?
  createdAt   DateTime            @default(now())
  vehicle     Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor       User?               @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([vehicleId, createdAt])
  @@index([companyId, createdAt])
  @@index([actorId])
}

model VehicleCostAggregate {
  id        String          @id @default(cuid())
  vehicleId String
  companyId String
  costType  VehicleCostType
  month     DateTime
  amount    Decimal         @db.Decimal(14, 2)
  distance  Decimal?        @db.Decimal(14, 2)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  vehicle   Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, costType, month])
  @@index([companyId, month])
  @@index([vehicleId, month])
}

model VehicleSavedFilter {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  scope     String   @default("fleet.vehicles")
  name      String
  filters   Json
  columns   Json?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, scope, name])
  @@index([companyId, userId, scope])
}
