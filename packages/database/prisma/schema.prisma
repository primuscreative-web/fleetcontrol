  @@index([companyId, status])
  @@index([companyId, branchId])
  @@index([companyId, city, state])
  @@index([companyId, rating])
  @@index([archivedAt])
}

model WorkshopService {
  id             String                  @id @default(cuid())
  companyId      String
  workshopId     String
  category       WorkshopServiceCategory
  name           String
  description    String?
  laborRate      Decimal?                @db.Decimal(14, 2)
  fixedPrice     Decimal?                @db.Decimal(14, 2)
  estimatedHours Decimal?                @db.Decimal(8, 2)
  warrantyDays   Int?
  active         Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  company        Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workshop       Workshop                @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([workshopId, name])
  @@index([companyId, category, active])
}

model WorkshopQuote {
  id                    String              @id @default(cuid())
  companyId             String
  workshopId            String
  maintenanceOrderId    String
  createdById           String?
  number                String
  status                WorkshopQuoteStatus @default(DRAFT)
  submittedAt           DateTime?
  validUntil            DateTime?
  estimatedStartAt      DateTime?
  estimatedCompletionAt DateTime?
  laborAmount           Decimal             @default(0) @db.Decimal(14, 2)
  partsAmount           Decimal             @default(0) @db.Decimal(14, 2)
  discountAmount        Decimal             @default(0) @db.Decimal(14, 2)
  totalAmount           Decimal             @default(0) @db.Decimal(14, 2)
  warrantyDays          Int?
  paymentTermsDays      Int?
  notes                 String?
  selectedAt            DateTime?
  rejectionReason       String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  company               Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workshop              Workshop            @relation(fields: [workshopId], references: [id], onDelete: Restrict)
  maintenanceOrder      MaintenanceOrder    @relation(fields: [maintenanceOrderId], references: [id], onDelete: Cascade)
  createdBy             User?               @relation("WorkshopQuoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items                 WorkshopQuoteItem[]

  @@unique([workshopId, number])
  @@unique([maintenanceOrderId, workshopId])
  @@index([companyId, status, validUntil])
  @@index([maintenanceOrderId, status])
}

model WorkshopQuoteItem {
  id          String              @id @default(cuid())
  companyId   String
  quoteId     String
  category    MaintenanceItemType
  description String
  sku         String?
  quantity    Decimal             @default(1) @db.Decimal(12, 3)
  unitPrice   Decimal             @default(0) @db.Decimal(14, 4)
  totalPrice  Decimal             @default(0) @db.Decimal(14, 2)
  createdAt   DateTime            @default(now())
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quote       WorkshopQuote       @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([companyId, category])
  @@index([quoteId])
}

model WorkshopEvaluation {
  id                 String           @id @default(cuid())
  companyId          String
  workshopId         String
  maintenanceOrderId String           @unique
  createdById        String?
  qualityScore       Int
  timelinessScore    Int
  serviceScore       Int
  costBenefitScore   Int
  overallScore       Decimal          @db.Decimal(4, 2)
  wouldRecommend     Boolean          @default(true)
  comments           String?
  createdAt          DateTime         @default(now())
  company            Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workshop           Workshop         @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  maintenanceOrder   MaintenanceOrder @relation(fields: [maintenanceOrderId], references: [id], onDelete: Cascade)
  createdBy          User?            @relation("WorkshopEvaluationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([workshopId, createdAt])
}
